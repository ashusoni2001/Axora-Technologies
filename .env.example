# Copy to `.env` and adjust. Vite only exposes vars prefixed with VITE_.
# In production, set these in the Vercel project's Environment Variables.

# Theme palette picker — developer-only feature flag.
#   on  -> show the floating base/accent theme switcher to visitors
#   off -> (default) site locked on the brand default, Frost · Aurora
VITE_THEME_PALETTE=off
